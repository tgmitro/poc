# --- Weather (OpenWeatherMap) ---
# Get a free key at https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_CITY=Bratislava
WEATHER_UNITS=metric

# --- Fio Banka SK ---
# Generate a token in your internet banking under:
# Settings -> API -> Add token
FIO_API_TOKEN=your_fio_banka_api_token_here

# --- Server ---
# Path to SSL cert/key files.
# Leave blank to use a self-signed (adhoc) certificate (requires pyopenssl).
# For production, point these at your Let's Encrypt or own cert files:
#   SSL_CERT=/etc/letsencrypt/live/yourdomain/fullchain.pem
#   SSL_KEY=/etc/letsencrypt/live/yourdomain/privkey.pem
SSL_CERT=
SSL_KEY=

HOST=0.0.0.0
PORT=4443

